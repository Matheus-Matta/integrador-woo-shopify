# ── Porta e fuso ──────────────────────────────────────────────────────────────
PORT=3005
TZ=America/Sao_Paulo

# ── HMAC ──────────────────────────────────────────────────────────────────────
# Deixe false em produção. Só true para testes locais sem Shopify real.
SKIP_HMAC=false

# ── Shopify ───────────────────────────────────────────────────────────────────
SHOPIFY_URL=https://sua-loja.myshopify.com/admin/api/2024-01/graphql.json
SHOPIFY_ACCESS_TOKEN=shpat_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# API secret key (Shopify Admin → Apps → API credentials → "API secret key")
SHOPIFY_WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── WooCommerce ───────────────────────────────────────────────────────────────
WOO_URL=https://sua-loja.com.br
WOO_KEY=ck_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
WOO_SECRET=cs_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
WOO_WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Redis ─────────────────────────────────────────────────────────────────────
# Em docker compose, o endereço é redis://:<senha>@redis:6379/1
REDIS_URL=redis://:300401@localhost:6379/1
REDIS_PASSWORD=300401
REDIS_CACHE_TTL_SECONDS=300

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Em docker compose, o endereço é mongodb://<user>:<senha>@mongodb:27017/integrador?authSource=admin
MONGODB_URL=mongodb://integrador:300401@localhost:27017/integrador?authSource=admin
MONGO_ROOT_USER=integrador
MONGO_ROOT_PASSWORD=300401

# ── Filas BullMQ ──────────────────────────────────────────────────────────────
QUEUE_ATTEMPTS=3
QUEUE_BACKOFF_DELAY_MS=5000

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_PASSWORD=troque_para_senha_forte
# Chave aleatória de 64+ caracteres para assinar os JWTs do dashboard
DASHBOARD_JWT_SECRET=troque_para_segredo_jwt_forte_de_64_chars_ou_mais

# ── Domínio público (usado para registrar webhooks) ───────────────────────────
DOMAIN=https://seu-dominio.com

# ─── Scheduler de verificação de sincronização ────────────────────────────
# Intervalo entre cada verificação (ms). Padrão: 1800000 = 30 min
SCHEDULER_INTERVAL_MS=1800000
# Janela de lookback: verifica registros modificados nas últimas N horas. Padrão: 2
SCHEDULER_LOOKBACK_HOURS=2

# ── Logs ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=production
