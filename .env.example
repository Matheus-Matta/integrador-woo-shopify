# Exemplo de variáveis de ambiente (não incluir valores sensíveis)
# URLs/ tokens de integração devem ser geridos via secret manager em produção

# Shopify
SHOPIFY_URL=https://sua-loja.myshopify.com/admin/api/2024-01/graphql.json
SHOPIFY_ACCESS_TOKEN=PLACEHOLDER
SHOPIFY_WEBHOOK_SECRET=PLACEHOLDER

# Public API (se houver)
NEXT_PUBLIC_API_BASE_URL=https://api.seudominio.com
# Configurações do Integrador Shopify ↔ WooCommerce
NEXT_PUBLIC_APP_NAME="Integrador Woo"

# Porta do servidor (padrão 3000)
PORT=3000
TZ=America/Sao_Paulo

# --- Shopify ---
# URL da API GraphQL (ex: https://loja.myshopify.com/admin/api/2024-01/graphql.json)
SHOPIFY_URL=
# Token de acesso do app privado (shpat_...)
SHOPIFY_ACCESS_TOKEN=
# Secret do webhook para validação HMAC
SHOPIFY_WEBHOOK_SECRET=

# --- WooCommerce ---
# URL base do site (ex: https://meusite.com.br)
WOO_URL=
# Consumer Key (ck_...)
WOO_KEY=
# Consumer Secret (cs_...)
WOO_SECRET=
# Secret do webhook para validação HMAC (definido ao criar o webhook no Woo)
WOO_WEBHOOK_SECRET=

# --- Bancos de Dados ---
# MongoDB URL para logs
MONGODB_URL=mongodb://localhost:27017/integrador
# Redis URL para filas e cache
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL_SECONDS=300

# --- Filas BullMQ ---
QUEUE_ATTEMPTS=3
QUEUE_BACKOFF_DELAY_MS=5000

# --- Dashboard & Segurança ---
# Senha para acessar o painel
DASHBOARD_PASSWORD=
# Segredo para assinatura do token JWT (mude para algo seguro!)
DASHBOARD_JWT_SECRET=

# --- Integração & Domínio ---
# Domínio público onde o integrador está exposto (ex: https://integrador.meudominio.com)
# Usado para registrar os webhooks automaticamente.
DOMAIN=

# --- Sincronizador Agendado ---
# Intervalo de verificação de pedidos perdidos (ms) - Padrão: 1 hora
SCHEDULER_INTERVAL_MS=3600000
# Janela de tempo para buscar pedidos no passado (horas)
SCHEDULER_LOOKBACK_HOURS=2

# --- Outros ---
# Pular validação HMAC (apenas para testes locais com ferramentas que não suportam)
SKIP_HMAC=false
# Rate Limiting
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000
